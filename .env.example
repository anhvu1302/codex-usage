# Local API + production server port. The server always binds to 127.0.0.1.
PORT=8787

# Optional: the Codex JSONL source directory.
# CODEX_SESSIONS_DIR=/Users/your-user/.codex/sessions

# Optional: SQLite destination. Keep this outside the project so deleting session files
# never deletes imported usage history.
# CODEX_USAGE_DB=/Users/your-user/.codex-usage/codex-usage.db
