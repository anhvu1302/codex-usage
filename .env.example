# Local API + production server port. The server always binds to 127.0.0.1.
PORT=8787

# Optional: Codex data root. Codex defaults to the current user's .codex directory.
# macOS/Linux example: CODEX_HOME=/Users/your-user/.codex
# Windows example (forward slashes are accepted): CODEX_HOME=C:/Users/your-user/.codex

# Optional: the Codex JSONL source directory.
# Overrides CODEX_HOME for this app when set.
# macOS/Linux example: CODEX_SESSIONS_DIR=/Users/your-user/.codex/sessions
# Windows example: CODEX_SESSIONS_DIR=C:/Users/your-user/.codex/sessions

# Optional: SQLite destination. Keep this outside the project so deleting session files
# never deletes imported usage history.
# macOS/Linux example: CODEX_USAGE_DB=/Users/your-user/.codex-usage/codex-usage.db
# Windows example: CODEX_USAGE_DB=C:/Users/your-user/.codex-usage/codex-usage.db
