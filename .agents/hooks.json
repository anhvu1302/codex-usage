{
  "codex-usage-pretool-guard": {
    "PreToolUse": [
      {
        "matcher": "^(view_file|write_to_file|replace_file_content|multi_replace_file_content|run_command|read_url_content|browser_.*|mcp_.*|define_subagent|invoke_subagent|manage_subagents|send_message)$",
        "hooks": [
          {
            "type": "command",
            "command": "bash .agents/hooks/pretool-guard.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
