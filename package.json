{
  "name": "codex-usage-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24.11.0",
    "pnpm": ">=11.5.0"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/server/index.ts",
    "build": "pnpm build:web && pnpm build:server",
    "build:web": "vite build",
    "build:server": "tsup",
    "start": "cross-env NODE_ENV=production node --max-old-space-size=64 --max-semi-space-size=4 build-server/index.js",
    "prod": "pnpm build && pnpm start",
    "pm2:start": "pnpm build && pm2 startOrRestart ecosystem.config.cjs --env production --update-env && pm2 save",
    "pm2:restart": "pnpm build && pm2 restart ecosystem.config.cjs --env production --update-env && pm2 save",
    "pm2:stop": "pm2 stop codex-usage",
    "pm2:delete": "pm2 delete codex-usage && pm2 save --force",
    "pm2:status": "pm2 show codex-usage",
    "pm2:logs": "pm2 logs codex-usage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/migrate.ts",
    "repair": "tsx src/server/repair.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "deadcode": "knip",
    "audit:prod": "pnpm audit --prod --audit-level high",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm test:e2e && pnpm deadcode && pnpm audit:prod"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.29",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-router": "^8.2.0",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.5",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-tailwindcss": "^4.1.0",
    "knip": "^6.26.0",
    "pm2": "^7.0.3",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
